{
  "name": "Task",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Auto-generated task ID like FW-25-0001"
    },
    "serial_number": {
      "type": "number"
    },
    "financial_year": {
      "type": "string"
    },
    "entry_date": {
      "type": "string",
      "format": "date"
    },
    "client_code": {
      "type": "string"
    },
    "client_name": {
      "type": "string"
    },
    "rm_assigned": {
      "type": "string"
    },
    "branch": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "Transaction",
        "Service",
        "Compliance",
        "Investment"
      ]
    },
    "action": {
      "type": "string"
    },
    "product_name": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "priority": {
      "type": "string",
      "enum": [
        "High",
        "Medium",
        "Low"
      ],
      "default": "Medium"
    },
    "assigned_to": {
      "type": "string"
    },
    "follow_up_date": {
      "type": "string",
      "format": "date"
    },
    "channel": {
      "type": "string",
      "enum": [
        "Call",
        "WhatsApp",
        "Email",
        "Meeting"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "Pending",
        "Under Process",
        "Waiting Client",
        "Completed",
        "Cancelled"
      ],
      "default": "Pending"
    },
    "reviewer_notes": {
      "type": "string"
    },
    "closure_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "client_name",
    "category",
    "action",
    "assigned_to",
    "follow_up_date"
  ]
}